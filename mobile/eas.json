{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_EMBER_APP_URL": "http://192.168.72.150:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_EMBER_APP_URL": "https://staging.your-ember-domain.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_EMBER_APP_URL": "https://your-ember-domain.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
