// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Image {
  id           String        @id @default(cuid())
  filename     String
  originalName String
  description  String?
  visibility   Visibility    @default(PRIVATE)
  createdAt    DateTime      @default(now())
  contributors Contributor[]
  wiki         Wiki?
  chatSessions ChatSession[]
}

model Contributor {
  id           String        @id @default(cuid())
  phoneNumber  String
  name         String?
  token        String        @unique @default(cuid()) // Secure token for web access
  inviteSent   Boolean       @default(false)
  imageId      String
  image        Image         @relation(fields: [imageId], references: [id], onDelete: Cascade)
  conversation Conversation?
  createdAt    DateTime      @default(now())
}

model Conversation {
  id            String      @id @default(cuid())
  contributorId String      @unique
  contributor   Contributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  status        String      @default("pending") // pending, active, completed
  currentStep   String      @default("greeting") // greeting, context, who, what, when, where, why, how, followup, closing
  messages      Message[]
  responses     Response[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "assistant" or "user"
  content        String
  createdAt      DateTime     @default(now())
}

model Response {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  questionType   String       // context, who, what, when, where, why, how, followup
  question       String
  answer         String
  createdAt      DateTime     @default(now())
}

model Wiki {
  id        String   @id @default(cuid())
  imageId   String   @unique
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  content   String   // Markdown content
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Visibility {
  PUBLIC
  PRIVATE
  SHARED
}

model AccessPass {
  id        String          @id @default(cuid())
  label     String?
  codeHash  String
  salt      String
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  revokedAt DateTime?
  sessions  AccessSession[]
}

model AccessSession {
  id        String     @id @default(cuid())
  token     String     @unique
  passId    String
  pass      AccessPass @relation(fields: [passId], references: [id], onDelete: Cascade)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  revokedAt DateTime?
}

model ChatSession {
  id        String        @id @default(cuid())
  browserId String
  imageId   String
  image     Image         @relation(fields: [imageId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  personaName String?
  personaTraits String?
  personaVoice String?
  personaBackstory String?

  @@unique([browserId, imageId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" or "assistant"
  content   String
  createdAt DateTime    @default(now())
}
