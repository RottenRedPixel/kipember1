// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Image {
  id           String        @id @default(cuid())
  filename     String
  originalName String
  description  String?
  visibility   Visibility    @default(PRIVATE)
  createdAt    DateTime      @default(now())
  contributors Contributor[]
  wiki         Wiki?
}

model Contributor {
  id           String        @id @default(cuid())
  phoneNumber  String
  name         String?
  token        String        @unique @default(cuid()) // Secure token for web access
  inviteSent   Boolean       @default(false)
  imageId      String
  image        Image         @relation(fields: [imageId], references: [id], onDelete: Cascade)
  conversation Conversation?
  createdAt    DateTime      @default(now())
}

model Conversation {
  id            String      @id @default(cuid())
  contributorId String      @unique
  contributor   Contributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  status        String      @default("pending") // pending, active, completed
  currentStep   String      @default("greeting") // greeting, context, who, what, when, where, why, how, followup, closing
  messages      Message[]
  responses     Response[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "assistant" or "user"
  content        String
  createdAt      DateTime     @default(now())
}

model Response {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  questionType   String       // context, who, what, when, where, why, how, followup
  question       String
  answer         String
  createdAt      DateTime     @default(now())
}

model Wiki {
  id        String   @id @default(cuid())
  imageId   String   @unique
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  content   String   // Markdown content
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Visibility {
  PUBLIC
  PRIVATE
  SHARED
}
