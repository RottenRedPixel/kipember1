    "@prisma/client": "^7.3.0",
    "dotenv": "^17.2.3",
    "exifr": "^7.1.3",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "nodemailer": "^7.0.5",
    "openai": "^6.29.0",
    "pg": "^8.20.0",
    "prisma": "^7.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.7",
